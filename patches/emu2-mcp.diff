     // NUL driver
     static const uint8_t null_device[] = {
         0xff, 0xff, 0x00, 0x00,                    // Next driver
@@ -2697,7 +2780,13 @@ void init_dos(int argc, char **argv)
 
 void intr28(void)
 {
-    usleep(1); // TODO: process messages?
+    // DOS idle interrupt — decrement InDOS flag temporarily so TSRs
+    // can safely call DOS functions during idle
+    if(dos_indos_addr && memory[dos_indos_addr + 1] > 0)
+        memory[dos_indos_addr + 1]--;
+    usleep(1);
+    if(dos_indos_addr)
+        memory[dos_indos_addr + 1]++;
 }
 
 void intr29(void)
@@ -2708,3 +2797,76 @@ void intr29(void)
     debug(debug_dos, "D-29:   fast console out  AX=%04X\n", ax);
     dos_putchar(ax & 0xFF, 1);
 }
+
+// INT 33h — Mouse driver (puppet mode for MCP automation)
+static int mouse_x = 0, mouse_y = 0;
+static int mouse_buttons = 0;    // Bit 0=left, bit 1=right
+static int mouse_visible = 0;
+static int mouse_x_min = 0, mouse_x_max = 639;
+static int mouse_y_min = 0, mouse_y_max = 199;
+static int mouse_mickey_x = 0, mouse_mickey_y = 0;
+
+void intr33(void)
+{
+    unsigned ax = cpuGetAX();
+    debug(debug_int, "D-33: AX=%04X\n", ax);
+    switch(ax)
+    {
+    case 0x0000: // Reset / Initialize
+        mouse_x = 0;
+        mouse_y = 0;
+        mouse_buttons = 0;
+        mouse_visible = 0;
+        mouse_x_min = 0;
+        mouse_x_max = 639;
+        mouse_y_min = 0;
+        mouse_y_max = 199;
+        mouse_mickey_x = 0;
+        mouse_mickey_y = 0;
+        cpuSetAX(0xFFFF);  // Mouse installed
+        cpuSetBX(2);       // 2 buttons
+        break;
+    case 0x0001: // Show cursor
+        mouse_visible = 1;
+        break;
+    case 0x0002: // Hide cursor
+        mouse_visible = 0;
+        break;
+    case 0x0003: // Get position & buttons
+        cpuSetBX(mouse_buttons);
+        cpuSetCX(mouse_x);
+        cpuSetDX(mouse_y);
+        break;
+    case 0x0004: // Set position
+        mouse_x = cpuGetCX();
+        mouse_y = cpuGetDX();
+        // Clamp to range
+        if(mouse_x < mouse_x_min) mouse_x = mouse_x_min;
+        if(mouse_x > mouse_x_max) mouse_x = mouse_x_max;
+        if(mouse_y < mouse_y_min) mouse_y = mouse_y_min;
+        if(mouse_y > mouse_y_max) mouse_y = mouse_y_max;
+        break;
+    case 0x0007: // Set X range
+        mouse_x_min = cpuGetCX();
+        mouse_x_max = cpuGetDX();
+        break;
+    case 0x0008: // Set Y range
+        mouse_y_min = cpuGetCX();
+        mouse_y_max = cpuGetDX();
+        break;
+    case 0x000B: // Get motion counters (mickeys)
+        cpuSetCX(mouse_mickey_x);
+        cpuSetDX(mouse_mickey_y);
+        mouse_mickey_x = 0;
+        mouse_mickey_y = 0;
+        break;
+    case 0x000C: // Set user handler — accept but ignore
+        break;
+    case 0x00FF: // Custom: set button state directly (BX = buttons)
+        mouse_buttons = cpuGetBX() & 3;
+        break;
+    default:
+        debug(debug_int, "UNHANDLED INT 33h, AX=%04x\n", ax);
+        break;
+    }
+}
