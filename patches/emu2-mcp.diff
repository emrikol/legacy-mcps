+    case 0x31: // KEEP PROCESS (TSR)
+    {
+        uint16_t keep_paras = cpuGetDX();
+        return_code = ax & 0xFF;
+        uint16_t psp = get_current_PSP();
+        debug(debug_dos, "\tTSR: PSP=%04X, keep %04X paragraphs, rc=%d\n",
