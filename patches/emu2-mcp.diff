diff --git a/src/main.c b/src/main.c
index 7d9c9f5..844e0c8 100644
--- a/src/main.c
+++ b/src/main.c
@@ -144,9 +144,48 @@ void bios_routine(unsigned inum)
     else if(inum == 0x2f)
         intr2f();
     else if(inum == 0x8)
-        ; // Timer interrupt - nothing to do
+    {
+        // Timer interrupt: increment BIOS tick counter at 0040:006C (4 bytes)
+        uint32_t ticks = get32(0x46C);
+        ticks++;
+        put32(0x46C, ticks);
+
+        // Chain to INT 1Ch (user timer tick) through the IVT.
+        // Stack currently has [ret_ip, ret_cs, ret_flags] from interrupt(8).
+        // We want the IRET (from do_instruction(0xCF)) to jump to INT 1Ch,
+        // and INT 1Ch's IRET to return to the original caller.
+        //
+        // Target stack layout (SP at top):
+        //   SP+0:  int1c_ip    ← IRET from here goes to INT 1Ch
+        //   SP+2:  int1c_cs
+        //   SP+4:  flags (IF=1)
+        //   SP+6:  ret_ip      ← INT 1Ch's IRET returns to original caller
+        //   SP+8:  ret_cs
+        //   SP+10: ret_flags
+        uint16_t ret_ip = cpuGetStack(0);
+        uint16_t ret_cs = cpuGetStack(2);
+        uint16_t ret_flags = cpuGetStack(4);
+        uint16_t int1c_ip = get16(0x1C * 4);
+        uint16_t int1c_cs = get16(0x1C * 4 + 2);
+
+        // Grow stack by 6 bytes for the extra IRET frame
+        cpuSetSP(cpuGetSP() - 6);
+        uint32_t sp_base = cpuGetSS() * 16 + cpuGetSP();
+
+        // Top: INT 1Ch entry (popped by the simulated IRET)
+        put16(sp_base + 0, int1c_ip);
+        put16(sp_base + 2, int1c_cs);
+        put16(sp_base + 4, ret_flags | 0x0200); // IF=1
+
+        // Below: original return (popped by INT 1Ch's IRET)
+        put16(sp_base + 6, ret_ip);
+        put16(sp_base + 8, ret_cs);
+        put16(sp_base + 10, ret_flags);
+    }
     else if(inum == 0x9)
         keyb_handle_irq(); // Keyboard interrupt
+    else if(inum == 0x33)
+        intr33(); // Mouse driver
     else
         debug(debug_int, "UNHANDLED INT %02x, AX=%04x\n", inum, cpuGetAX());
 }
@@ -328,7 +367,8 @@ int main(int argc, char **argv)
     timer_action.sa_handler = timer_alarm;
     sigemptyset(&exit_action.sa_mask);
     sigemptyset(&timer_action.sa_mask);
-    exit_action.sa_flags = timer_action.sa_flags = 0;
+    exit_action.sa_flags = 0;
+    timer_action.sa_flags = SA_RESTART; // Restart syscalls interrupted by timer
     sigaction(SIGALRM, &timer_action, NULL);
     // Install an exit handler to allow exit functions to run
     sigaction(SIGHUP, &exit_action, NULL);
