+
+        // Check if this is the top-level process (parent PSP == 0xFFFE)
+        if(0xFFFE == get16(cpuGetAddress(psp, 22)))
+        {
+            // No parent — enter idle loop: HLT + JMP $-1
+            // Write a tiny stub: F4 EB FD (HLT; JMP $-1)
+            // Place it at a safe location in high memory
+            uint32_t stub = 0xFE100;
+            memory[stub] = 0xF4;     // HLT
+            memory[stub + 1] = 0xEB; // JMP short
+            memory[stub + 2] = 0xFD; // -3 (back to HLT)
+            // Modify the IRET return address on stack to point to our HLT stub.
+            // The INT 21h was invoked via interrupt(), which pushed FLAGS/CS/IP.
+            // The stack was saved at entry: PSP offset 0x2E=SP, 0x30=SS.
+            // We need to modify the IRET frame that bios_routine's simulated
+            // IRET (do_instruction(0xCF)) will pop.
+            // The IRET frame is at current SS:SP (pushed by interrupt()).
+            int stack = cpuGetAddress(cpuGetSS(), cpuGetSP());
+            put16(stack + 0, stub & 0xF);       // IP = stub offset
+            put16(stack + 2, stub >> 4);         // CS = stub segment
+            put16(stack + 4, 0x0202);            // FLAGS with IF=1
+        }
+        else
+        {
+            // Has parent — return to parent like EXIT but keep memory
+            // Restore INT 22h, 23h, 24h from PSP
+            put16(0x88, get16(cpuGetAddress(psp, 10)));
+            put16(0x8A, get16(cpuGetAddress(psp, 12)));
+            put16(0x8C, get16(cpuGetAddress(psp, 14)));
+            put16(0x8E, get16(cpuGetAddress(psp, 16)));
+            put16(0x90, get16(cpuGetAddress(psp, 18)));
+            put16(0x92, get16(cpuGetAddress(psp, 20)));
+            // Set PSP to parent
+            set_current_PSP(get16(cpuGetAddress(psp, 22)));
+            // Get parent's saved stack
+            cpuSetSS(get16(cpuGetAddress(get_current_PSP(), 0x30)));
+            cpuSetSP(get16(cpuGetAddress(get_current_PSP(), 0x2E)));
+            int stack = cpuGetAddress(cpuGetSS(), cpuGetSP());
+            // Fixup interrupt return to INT 22h handler
+            put16(stack, get16(0x22 * 4));
+            put16(stack + 2, get16(0x22 * 4 + 2));
+            put16(stack + 4, 0xf202);
+        }
+        break;
+    }
     case 0x33: // BREAK SETTINGS
